/* ======================================================
GENERATE DICTIONARY
====================================================== */

let dictionary = {}

function normalize(text){

return text.toLowerCase().trim()

}

function addPart(part){

const key = normalize(part)

if(!dictionary[key]){

dictionary[key]={
aliases:new Set()
}

}

/* alias rules */

for(const rule of aliasRules){

if(part.includes(rule[0])){

const alias = part.replace(rule[0],rule[1])

dictionary[key].aliases.add(alias)

}

}

}

/* build dictionary */

for(const category in BASE_PARTS){

for(const part of BASE_PARTS[category]){

addPart(part)

}

}

/* expand positions */

const positions=["front","rear","left","right"]

for(const part in dictionary){

for(const pos of positions){

const variant = pos+" "+part

dictionary[part].aliases.add(variant)

}

}

/* convert set → array */

for(const part in dictionary){

dictionary[part].aliases=[...dictionary[part].aliases]

}

/* ======================================================
SAVE FILE
====================================================== */

fs.writeFileSync(
"./parts_dictionary.json",
JSON.stringify(dictionary,null,2)
)

console.log("Ultimate parts dictionary generated.")
console.log("Total parts:",Object.keys(dictionary).length)
