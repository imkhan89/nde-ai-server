/*
Vehicle Learning Engine
Learns vehicle ranges from product titles
*/

const fs = require("fs")
const path = require("path")

const MEMORY_FILE =
path.join(__dirname,"../data/vehicle_range_memory.json")

const PRODUCT_INDEX =
path.join(__dirname,"../data/product_index.json")

let memory = {}

/* LOAD MEMORY */

function loadMemory(){

try{

if(fs.existsSync(MEMORY_FILE)){

const raw =
fs.readFileSync(MEMORY_FILE,"utf8")

memory = JSON.parse(raw || "{}")

}

}catch(e){

memory = {}

}

}

loadMemory()

/* SAVE MEMORY */

function saveMemory(){

try{

fs.writeFileSync(
MEMORY_FILE,
JSON.stringify(memory,null,2)
)

}catch(e){}

}

/* NORMALIZE */

function normalize(text){

return (text || "")
.toLowerCase()
.replace(/[^\w\s]/g," ")
.replace(/\s+/g," ")
.trim()

}

/* LEARN VEHICLE */

function learn(make,model,range){

if(!make || !model || !range) return

const key =
`${make.toLowerCase()} ${model.toLowerCase()}`

memory[key] = range

saveMemory()

}

/* LEARN FROM TITLE */

function learnFromTitle(title){

const clean = normalize(title)

const rangeMatch =
clean.match(/(\d{4}-\d{4})/)

if(!rangeMatch) return

const range = rangeMatch[1]

const brands = [
"suzuki",
"toyota",
"honda",
"kia",
"hyundai",
"mg"
]

for(const brand of brands){

if(clean.includes(brand)){

const words = clean.split(" ")

const index = words.indexOf(brand)

if(index !== -1 && words[index+1]){

const model = words[index+1]

learn(brand,model,range)

}

}

}

}

/* LEARN FROM PRODUCT INDEX */

function learnFromProducts(){

try{

if(!fs.existsSync(PRODUCT_INDEX)) return

const raw =
fs.readFileSync(PRODUCT_INDEX,"utf8")

const products =
JSON.parse(raw || "[]")

for(const p of products){

const title = p.title || ""

learnFromTitle(title)

}

}catch(e){}

}

/* DETECT RANGE */

function detectRange(make,model){

if(!make || !model) return null

const key =
`${make.toLowerCase()} ${model.toLowerCase()}`

if(memory[key]){

return memory[key]

}

return null

}

module.exports = {

learn,
learnFromTitle,
learnFromProducts,
detectRange

}
